GHCR_OWNER=your-github-owner

APP_ENV=production
TZ=Asia/Shanghai
APP_NAME=AutoMATA
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8005

DB_USER=automata
DB_PASSWORD=replace-with-strong-password
DB_HOST=mysql
DB_PORT=3306
DB_NAME=automata
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

# REFERENCE_DATA_SQL_DIR=/app/reference_sql
# Release 附件名写死在仓库 .github/workflows/deploy.yml（automata-reference-sql.tar.gz）

SECRET_KEY=replace-with-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

MAX_UPLOAD_SIZE=524288000
UPLOAD_DIR=./uploaded_files
ALLOWED_FILE_TYPES=["txt","csv","tsv","xlsx","xls","pth","pkl"]

REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["https://your-domain.com"]

EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SSL=false
SMTP_FROM_NAME=AutoMATA
