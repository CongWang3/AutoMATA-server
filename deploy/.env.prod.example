# 手工执行 docker compose 时请加：--env-file .env.prod
# （否则镜像会默认拉 ghcr.io、MySQL 相关插值可能为空，出现 manifest unknown / 后端无限重启）
ALIYUN_REGISTRY=crpi-c0pltk6mq32oe9t3.cn-hangzhou.personal.cr.aliyuncs.com

# 镜像标签（CI 部署常设为 commit SHA；手工部署可与当前运行版本一致）
FRONTEND_IMAGE_TAG=latest
BACKEND_IMAGE_TAG=latest

# 镜像仓库组织/用户名（GHCR，仅文档用）
GHCR_OWNER=your-github-owner

# 宿主机端口（开发/生产同机时可避免冲突）
FRONTEND_HOST_PORT=8080
BACKEND_HOST_PORT=18005
DOWNLOAD_HOST_PORT=18001

# 应用配置
APP_NAME=AutoMATA
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8005

# 独立下载服务
DOWNLOAD_SERVER_HOST=0.0.0.0
DOWNLOAD_SERVER_PORT=8001
# 同域名路径反代推荐值（由 Apache 代理到 download-server）
DOWNLOAD_PUBLIC_BASE_URL=https://your-domain.com/download
PYTHON_EXEC_PATH=python
RSCRIPT_PATH=/usr/bin/Rscript

# 数据库配置（容器内服务名）
DB_USER=automata
DB_PASSWORD=replace-with-strong-password
DB_HOST=mysql
DB_PORT=3306
DB_NAME=automata
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

# 参考注释库 SQL（compose 挂载 ./data/reference_sql -> /app/reference_sql）
# 方案 B：Release 附件名在 deploy.yml 写死；若仅用「下载 yml + SSH 部署」，CI 会向 .env.prod 自动追加 REFERENCE_DATA_SQL_DIR=/app/reference_sql，部署机无需手改。
# 本地自建 .env.prod 时可取消下行注释；与 CI 并存时每次部署会被覆盖为 /app/reference_sql
# REFERENCE_DATA_SQL_DIR=/app/reference_sql

# 安全配置
SECRET_KEY=replace-with-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传
MAX_UPLOAD_SIZE=524288000
UPLOAD_DIR=./uploaded_files
ALLOWED_FILE_TYPES=["txt","csv","tsv","xlsx","xls","pth","pkl"]

# Redis（容器内服务名）
REDIS_URL=redis://redis:6379/0

# 生产 CORS（按你的域名改）
CORS_ORIGINS=["https://your-domain.com"]

# 邮件（按需）
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SSL=false
SMTP_FROM_NAME=AutoMATA

# AI Agent（按需）
AGENT_ENABLED=false
AGENT_DEFAULT_PROVIDER=openai
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_BASE_URL=
AGENT_OPENAI_MODEL=gpt-4o
AGENT_QWEN_API_KEY=
AGENT_QWEN_MODEL=qwen-plus
AGENT_DEEPSEEK_API_KEY=
AGENT_DEEPSEEK_MODEL=deepseek-chat
AGENT_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AGENT_MAX_TURNS=10
