# 应用配置
APP_NAME=AutoMATA
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DB_USER=automata
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=3306
DB_NAME=automata
# Unix Socket 连接（可选，优先级高于 TCP 连接）
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# JWT 配置（生产环境必须修改）
# 示例安全密钥（请在生产环境生成新的随机密钥）：
# SECRET_KEY=awLqjzJVlBAg9rZs9yi86SweGCEgHQfU_qFyQGK4IFk
SECRET_KEY=4Fmbn2CcRtpWyjgeDUAW5nQIZ0lrMhDqF7AQO_DEu7Y
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传配置
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=./uploaded_files

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# CORS 配置（前端域名白名单）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email Configuration（邮件通知配置）
EMAIL_ENABLED=true
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASSWORD=your_smtp_password_or_auth_code
SMTP_SSL=true
SMTP_FROM_NAME=AutoMATA
