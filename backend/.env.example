# 应用配置
APP_NAME=AutoMATA
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DB_USER=automata
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=3306
DB_NAME=automata

# JWT 配置（生产环境必须修改）
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传配置
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=./uploaded_files

# Redis 配置
REDIS_URL=redis://localhost:6379/0
