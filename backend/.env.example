# 应用配置
APP_NAME=AutoMATA
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置 — 本地：复制本文件为 backend/.env（与 main.py 同目录，Settings 始终从该路径读取，与终端 cwd 无关）
# 生产：勿使用本文件；在 deploy/.env.prod（或部署平台密钥）中单独配置强密码，与本地 .env 区分
DB_USER=automata
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=3306
DB_NAME=automata
# Unix Socket 连接（可选，优先级高于 TCP 连接）
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# 参考注释表（MySQL）：生产挂载 ./data/reference_sql；本地可指向该目录绝对路径，表为空时启动导入
# REFERENCE_DATA_SQL_DIR=/xp/www/AutoMATA/data/reference_sql

# JWT 配置（生产环境必须修改）
# 示例安全密钥（请在生产环境生成新的随机密钥）：
# SECRET_KEY=awLqjzJVlBAg9rZs9yi86SweGCEgHQfU_qFyQGK4IFk
SECRET_KEY=4Fmbn2CcRtpWyjgeDUAW5nQIZ0lrMhDqF7AQO_DEu7Y
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传配置
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=./uploaded_files

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 独立下载服务 download_server.py（默认监听 8001）
# DOWNLOAD_PUBLIC_BASE_URL=http://localhost:8001
# 说明：DEBUG=True 且保持默认 URL 时，后端返回 /job-result/... 等同源路径，由 Vite 反代到 8001，本地浏览器不必转发 8001。
# 若远程开发且 IDE 将「远程 8001」映射到本机 3450，又希望 API 返回绝对地址，可设为 http://localhost:3450

# CORS 配置（前端域名白名单）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email Configuration（邮件通知配置）
EMAIL_ENABLED=true
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASSWORD=your_smtp_password_or_auth_code
SMTP_SSL=true
SMTP_FROM_NAME=AutoMATA
