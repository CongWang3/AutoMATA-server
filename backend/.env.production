# =============================================================================
# 生产/预发布 — 仅当进程环境 APP_ENV=production（或 prod）时加载；Docker 通常无此文件、只靠 Compose 注入
# 时区：生产容器请在 Compose / 平台设置 TZ=Asia/Shanghai（见 docker-compose.prod.yml、Dockerfile）
# =============================================================================
# 本地模拟生产：export APP_ENV=production 后启动 uvicorn，或在本机 .env.production.local 填密码

DEBUG=False
APP_NAME=AutoMATA
APP_VERSION=1.0.0
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8005

# Docker Compose 内由 .env.prod 覆盖为 mysql / 强密码
DB_USER=automata
DB_PASSWORD=
DB_HOST=mysql
DB_PORT=3306
DB_NAME=automata

# 生产必须替换；勿使用仓库默认值上线
SECRET_KEY=replace-with-random-secret-in-deploy-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

MAX_UPLOAD_SIZE=524288000
UPLOAD_DIR=./uploaded_files

REDIS_URL=redis://redis:6379/0

DOWNLOAD_PUBLIC_BASE_URL=

# 按实际站点修改；勿在生产使用 *
CORS_ORIGINS=["https://your-domain.com"]

EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SSL=false
SMTP_FROM_NAME=AutoMATA

AGENT_ENABLED=false
AGENT_DEFAULT_PROVIDER=openai
